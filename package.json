    "clsx": "^2.0.0",
    "i18next": "^26.3.2",
    "i18next-http-backend": "^4.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hot-toast": "^2.4.0",
    "react-i18next": "^17.0.7",
    "react-redux": "^9.2.0",
    "react-router": "^8.0.1",
    "react-use": "^17.6.1",
    "redux": "^5.0.1",
    "tailwind-merge": "^3.6.0"
  }
